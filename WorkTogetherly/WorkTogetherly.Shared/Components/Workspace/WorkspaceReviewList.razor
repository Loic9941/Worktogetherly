@inject ReviewService ReviewService

<MudPaper Elevation="3" Class="pa-4">
    <MudText Typo="Typo.h6" Class="mb-3">Avis reçus</MudText>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_reviews.Count == 0)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Text">Aucun avis pour le moment.</MudAlert>
    }
    else
    {
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
            <MudRating ReadOnly="true" SelectedValue="@((int)Math.Round(_averageRating))" MaxValue="5" Size="Size.Medium" Color="Color.Warning" />
            <MudText Typo="Typo.body1"><b>@_averageRating.ToString("0.0")</b> / 5</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">(@_reviews.Count avis)</MudText>
        </MudStack>

        <MudStack Spacing="2">
            @foreach (var review in _reviews)
            {
                <MudPaper Outlined="true" Class="pa-3">
                    <MudStack Spacing="1">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudRating ReadOnly="true" SelectedValue="review.Rating" MaxValue="5" Size="Size.Small" Color="Color.Warning" />
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                @(review.ReviewerName ?? "Utilisateur anonyme") · @review.CreatedAt.ToString("dd/MM/yyyy")
                            </MudText>
                        </MudStack>
                        @if (!string.IsNullOrWhiteSpace(review.Comment))
                        {
                            <MudText Typo="Typo.body2">@review.Comment</MudText>
                        }
                    </MudStack>
                </MudPaper>
            }
        </MudStack>
    }
</MudPaper>

@code {
    [Parameter, EditorRequired] public int WorkspaceId { get; set; }

    private List<ReviewDto> _reviews = [];
    private double _averageRating;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _reviews = await ReviewService.GetByWorkspaceAsync(WorkspaceId);
        _averageRating = _reviews.Count > 0 ? _reviews.Average(r => r.Rating) : 0;
        _loading = false;
    }
}
