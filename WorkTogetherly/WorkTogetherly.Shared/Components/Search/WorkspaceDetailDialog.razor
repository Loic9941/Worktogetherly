@inject WorkspaceService WorkspaceService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@WorkspaceName</MudText>
    </TitleContent>
    <DialogContent>
        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
        }
        else if (_details is null)
        {
            <MudAlert Severity="Severity.Error">Impossible de charger les détails de cet espace.</MudAlert>
        }
        else
        {
            @if (DistanceKm.HasValue)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.LocationOn" Color="Color.Primary" Size="Size.Small" />
                    <MudText Typo="Typo.body2">
                        @(DistanceKm < 1 ? "< 1 km" : $"~{DistanceKm:0.0} km")
                    </MudText>
                </MudStack>
            }

            @if (_details.ReviewCount > 0)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-2">
                    @for (int i = 1; i <= 5; i++)
                    {
                        var index = i;
                        <MudIcon Icon="@(index <= Math.Round(_details.AverageRating) ? Icons.Material.Filled.Star : Icons.Material.Outlined.StarOutline)"
                                 Color="Color.Warning" Size="Size.Small" />
                    }
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        @_details.AverageRating.ToString("0.0") (@_details.ReviewCount avis)
                    </MudText>
                </MudStack>
            }

            <MudText Typo="Typo.body2" Class="mb-3">@_details.Description</MudText>

            @if (WorkspaceMaterials.Count > 0)
            {
                <MudText Typo="Typo.subtitle2" Class="mb-1">Matériel</MudText>
                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mb-3">
                    @foreach (var m in WorkspaceMaterials)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                            @($"{m.Name} ×{m.Quantity}")
                        </MudChip>
                    }
                </MudStack>
            }

            @if (WorkspaceRules.Count > 0)
            {
                <MudText Typo="Typo.subtitle2" Class="mb-1">Règles</MudText>
                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mb-3">
                    @foreach (var r in WorkspaceRules)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined">@r.Name</MudChip>
                    }
                </MudStack>
            }

            <MudDivider Class="mb-3" />

            <MudText Typo="Typo.subtitle1" Class="mb-2">
                Créneaux du @SearchDate.ToString("dddd d MMMM yyyy", new System.Globalization.CultureInfo("fr-FR"))
            </MudText>

            @if (_details.Slots.Count == 0)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">Aucun créneau disponible pour cette date.</MudText>
            }
            else
            {
                @foreach (var slot in _details.Slots)
                {
                    <MudCard Class="mb-2" Elevation="1">
                        <MudCardContent Class="py-2">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.body1">
                                        @slot.StartDateTime.ToString("HH:mm") – @slot.EndDateTime.ToString("HH:mm")
                                    </MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        @slot.AvailablePlaces place(s) disponible(s) / @slot.Capacity
                                    </MudText>
                                </MudStack>

                                @if (slot.UserHasBooked)
                                {
                                    <MudChip T="string" Color="Color.Success" Size="Size.Small"
                                             Icon="@Icons.Material.Filled.Check" Variant="Variant.Filled">
                                        Réservé
                                    </MudChip>
                                }
                                else
                                {
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                               StartIcon="@Icons.Material.Filled.EventAvailable"
                                               OnClick="@(() => OpenBookingConfirmAsync(slot.Id, slot.StartDateTime, slot.EndDateTime, slot.MaterialAvailabilities))">
                                        <span class="d-none d-md-inline">Réserver</span>
                                    </MudButton>
                                }
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                }
            }
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Close" OnClick="Close">
            <span class="d-none d-md-inline">Fermer</span>
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public int WorkspaceId { get; set; }
    [Parameter] public string WorkspaceName { get; set; } = string.Empty;
    [Parameter] public DateOnly SearchDate { get; set; }
    [Parameter] public double? DistanceKm { get; set; }

    private WorkspaceDetailDto? _details;
    private bool _loading;

    private List<WorkspaceMaterialDto> WorkspaceMaterials => _details?.Materials ?? [];
    private List<WorkspaceRuleDto> WorkspaceRules => _details?.Rules ?? [];

    protected override async Task OnInitializedAsync()
    {
        await LoadDetailsAsync();
    }

    private async Task LoadDetailsAsync()
    {
        _loading = true;
        _details = await WorkspaceService.GetWorkspaceDetailsAsync(WorkspaceId, SearchDate);
        _loading = false;
    }

    private async Task OpenBookingConfirmAsync(int slotId, DateTime slotStart, DateTime slotEnd, List<SlotMaterialAvailabilityDto> materialAvailabilities)
    {
        var parameters = new DialogParameters
        {
            { nameof(BookingConfirmDialog.SlotId), slotId },
            { nameof(BookingConfirmDialog.SlotStart), slotStart },
            { nameof(BookingConfirmDialog.SlotEnd), slotEnd },
            { nameof(BookingConfirmDialog.WorkspaceName), WorkspaceName },
            { nameof(BookingConfirmDialog.MaterialAvailabilities), materialAvailabilities }
        };

        var dialog = await DialogService.ShowAsync<BookingConfirmDialog>("Réserver", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            Snackbar.Add("Réservation confirmée !", Severity.Success);
            await LoadDetailsAsync();
        }
    }

    private void Close() => MudDialog.Close();
}
