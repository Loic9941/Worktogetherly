@page "/forgot-password"
@using MudBlazor
@using WorkTogetherly.Shared.Services
@inject UserService UserService
@inject NavigationManager Navigation

<PageTitle>Mot de passe oublié</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraSmall">
    <MudCard Elevation="10">
        <MudCardContent>
            <MudGrid Spacing="3">
                <MudItem xs="12" Class="d-flex justify-start">
                    <img src="_content/WorkTogetherly.Shared/images/full_logo.png" alt="WorkTogetherly" style="max-width: 260px; width: 100%;" />
                </MudItem>
                <MudItem xs="12">
                    <MudText Typo="Typo.h5">Mot de passe oublié</MudText>
                    <MudText Typo="Typo.body2">Saisissez votre email pour recevoir un lien de réinitialisation.</MudText>
                </MudItem>

                @if (_sent)
                {
                    <MudItem xs="12">
                        <MudAlert Severity="Severity.Success" Variant="Variant.Filled">
                            Si cet email est associé à un compte, vous recevrez un lien de réinitialisation dans quelques instants.
                        </MudAlert>
                    </MudItem>
                }
                else
                {
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_email" Label="Email"
                                      Variant="Variant.Outlined" InputType="InputType.Email" />
                    </MudItem>
                    @if (!string.IsNullOrEmpty(_error))
                    {
                        <MudItem xs="12">
                            <MudText Color="Color.Error">@_error</MudText>
                        </MudItem>
                    }
                }
            </MudGrid>
        </MudCardContent>
        <MudCardActions Class="px-4">
            @if (!_sent)
            {
                <MudButton Variant="Variant.Filled" FullWidth Color="Color.Tertiary"
                           OnClick="SubmitAsync" Disabled="_isSubmitting">
                    @(_isSubmitting ? "Envoi en cours..." : "Envoyer le lien")
                </MudButton>
            }
        </MudCardActions>
        <MudCardActions Class="px-4 mb-4">
            <MudLink Color="Color.Default" Href="/login">Retour à la connexion</MudLink>
        </MudCardActions>
    </MudCard>
</MudContainer>

@code {
    private string _email = string.Empty;
    private bool _isSubmitting;
    private bool _sent;
    private string? _error;

    private async Task SubmitAsync()
    {
        if (_isSubmitting) return;
        _isSubmitting = true;
        _error = null;

        try
        {
            var (success, error) = await UserService.ForgotPasswordAsync(_email);
            if (success)
                _sent = true;
            else
                _error = error ?? "Une erreur est survenue.";
        }
        catch
        {
            _error = "Une erreur est survenue.";
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
