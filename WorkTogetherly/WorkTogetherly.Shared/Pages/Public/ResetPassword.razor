@page "/reset-password"
@using MudBlazor
@using WorkTogetherly.Shared.Services
@inject UserService UserService
@inject NavigationManager Navigation

<PageTitle>Nouveau mot de passe</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraSmall">
    <MudCard Elevation="10">
        <MudCardContent>
            <MudGrid Spacing="3">
                <MudItem xs="12" Class="d-flex justify-start">
                    <img src="_content/WorkTogetherly.Shared/images/full_logo.png" alt="WorkTogetherly" style="max-width: 260px; width: 100%;" />
                </MudItem>
                <MudItem xs="12">
                    <MudText Typo="Typo.h5">Nouveau mot de passe</MudText>
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_password" Label="Nouveau mot de passe"
                                  Variant="Variant.Outlined" InputType="InputType.Password" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_confirm" Label="Confirmer le mot de passe"
                                  Variant="Variant.Outlined" InputType="InputType.Password"
                                  Error="@_mismatch" ErrorText="Les mots de passe ne correspondent pas" />
                </MudItem>
                @if (!string.IsNullOrEmpty(_error))
                {
                    <MudItem xs="12">
                        <MudText Color="Color.Error">@_error</MudText>
                    </MudItem>
                }
            </MudGrid>
        </MudCardContent>
        <MudCardActions Class="px-4 mb-4">
            <MudButton Variant="Variant.Filled" FullWidth Color="Color.Tertiary"
                       OnClick="SubmitAsync" Disabled="_isSubmitting">
                @(_isSubmitting ? "Réinitialisation..." : "Réinitialiser le mot de passe")
            </MudButton>
        </MudCardActions>
    </MudCard>
</MudContainer>

@code {
    private string _password = string.Empty;
    private string _confirm = string.Empty;
    private bool _isSubmitting;
    private string? _error;
    private bool _mismatch => !string.IsNullOrEmpty(_confirm) && _password != _confirm;

    private string _email = string.Empty;
    private string _token = string.Empty;

    protected override void OnInitialized()
    {
        var uri = new Uri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        _email = query["email"] ?? string.Empty;
        _token = query["token"] ?? string.Empty;

        if (string.IsNullOrEmpty(_email) || string.IsNullOrEmpty(_token))
            Navigation.NavigateTo("/forgot-password", replace: true);
    }

    private async Task SubmitAsync()
    {
        if (_isSubmitting) return;
        if (_password != _confirm)
        {
            _error = "Les mots de passe ne correspondent pas.";
            return;
        }

        _isSubmitting = true;
        _error = null;

        try
        {
            var (success, error) = await UserService.ResetPasswordAsync(_email, _token, _password);
            if (success)
                Navigation.NavigateTo("/login?reset=1", replace: true);
            else
                _error = error ?? "Le lien est invalide ou expiré.";
        }
        catch
        {
            _error = "Une erreur est survenue.";
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
